{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Skills Manifest",
  "type": "object",
  "required": ["version", "framework", "skills"],
  "properties": {
    "version": { "type": "string" },
    "framework": { "type": "string", "enum": ["angular", "react", "vue"] },
    "skills": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
